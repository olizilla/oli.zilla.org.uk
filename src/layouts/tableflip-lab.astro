---
const { frontmatter, headings } = Astro.props;
const title = frontmatter?.title || Astro.props.title || headings?.find(h => h.depth === 1)?.text;
const tagline = frontmatter?.tagline || Astro.props.tagline || "Oli Evans (olizilla) — software engineer, co-operator, and writer. Thoughts on open source, open protocols, and web development.";
---
<!doctype html>
<html>
<head>
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{title}</title>
	<meta name="description" content={tagline} />
	<link href="/res/img/olizilla-trace.min.svg" rel="icon" type="image/svg+xml" />
  <style>
  body {
    text-align:center;
    margin:0;
    background: #F7F7F7;
    overflow: hidden;
  }
  .tableflip {
    display: block;
    width:30px;
    height: 34px;
    position: absolute;
    top: 20px;
    left:18px;
    background: url(https://tableflip.io/img/tableflip.min.svg) no-repeat;
    background-size: 100% auto;
    font-size:0;
    user-select: none;
    opacity: 0.8;
    transition: all 400ms;
  }
  .tableflip:hover {
    opacity: 1;
  }
  </style>
</head>
<body>
  <a title="(╯°□°）╯︵ TABLEFLIP" class="tableflip" href="../../../">TABLEFLIP</a>
  <slot/>
</body>
</html>

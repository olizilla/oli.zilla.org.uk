---
const { frontmatter, headings } = Astro.props;
const title = frontmatter?.title || Astro.props.title || headings?.find(h => h.depth === 1)?.text;
const tagline = frontmatter?.tagline || Astro.props.tagline || "Oli Evans (olizilla) — software engineer, co-operator, and writer. Thoughts on open source, open protocols, and web development.";
---
<!doctype html>
<html>
<head>
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{title}</title>
	<meta name="description" content={tagline} />
	<link rel="stylesheet" href="/css/atoms.css" />
	<link href="/rss.xml" rel="alternate" title="RSS" type="application/rss+xml" />
	<link href="/res/img/olizilla-trace.min.svg" rel="icon" type="image/svg+xml" />
</head>
<body class="bg-gray-1">
	<header class="max-width-1 m-x-auto p-y-3">
		<h1 class="p-y-3 text-center">
			<a class="block font-xl" href="/blog">
				<img title="is that supposed to go there?" alt="logo" src="/res/img/olizilla-trace.min.svg" style="width:140px; height:140px; vertical-align:-1em;" />
				<span class="bg-gray-1 uppercase bolder " style="letter-spacing:1px; border-bottom: hsl(0,20%,20%) solid 25px;">olizilla</span>
			</a>
		</h1>
	</header>
	<div class="content max-width-1 m-x-auto p-x-1 p-y-3">
		<slot/>
	</div>
</body>
</html>

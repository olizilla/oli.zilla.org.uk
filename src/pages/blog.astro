---
import Layout from '../layouts/2025.astro'
import { getCollection } from 'astro:content'
import Time from '../components/Time.astro'
const title = "Is that supposed to go there? A blog by olizilla"
const tagline = "A blog by Oli Evans (olizilla) about open source, open protocols, digital public infrastructure, and web development."
const rawPosts = (await getCollection('posts').then(posts => posts.filter(p => !p.data.draft))).reverse()
const posts = await Promise.all(rawPosts.map(async p => {
	const isoDateStr = p.id.slice(0, 10)
	const date = new Date(isoDateStr)
	const content = await p.render()
	const title = p.data.title ?? content.headings.at(0)?.text
  const link = p.data.link ?? `/${p.slug}`
  const image = p.data.image
  const tagline = p.data.tagline
	return { ...p, date, title, link, image, tagline }
}))

---
<Layout title={title} tagline={tagline} logoLink="/">
	<nav>
		{ posts.map(post => (
			<section>
					<h1>
						<a href={ post.link } class="font-extrabold">{ post.title ?? '?' }</a>
					</h1>
					{ post.tagline && <p class="text-zinc-600 pt-0 italic">{post.tagline}</p> }
					{ post.image && <img src={post.image} /> }
					<small class="block text-right text-sm font-mono uppercase tracking-wide text-zinc-600 -mb-1 pt-2"><Time date={post.date} /></small>
					<hr class="mt-2" />
			</section>
		)) }
	</nav>
</Layout>